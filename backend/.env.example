# Server
NODE_ENV=development
PORT=5000

# MongoDB (use container name in Docker, localhost for local dev)
MONGODB_URI=mongodb://spot-the-phish-mongo:27017/spot_the_phish

# Frontend origin allowed by CORS
CLIENT_ORIGIN=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Swagger docs URL base (optional)
API_DOCS_PATH=/api/docs

# JWT
JWT_ACCESS_SECRET=changeme-min-16-chars
JWT_REFRESH_SECRET=changeme-min-16-chars

# Admin credentials
ADMIN_USERNAME=admin22
ADMIN_PASSWORD=changeme
ADMIN_JWT_SECRET=your-admin-jwt-secret-min-16-chars
