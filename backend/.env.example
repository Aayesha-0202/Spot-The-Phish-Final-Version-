# Server
NODE_ENV=development
PORT=5000

# MongoDB (use the service name "mongo" inside Docker Compose)
MONGO_URI=mongodb://mongo:27017/spotthephish
# For local (non-Docker) development use:
# MONGO_URI=mongodb://localhost:27017/spotthephish

# Frontend origin allowed by CORS
CLIENT_ORIGIN=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Swagger docs URL base (optional)
API_DOCS_PATH=/api/docs
