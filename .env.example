# Root-level defaults for Docker Compose overrides (optional).
# The compose file already sets sensible defaults inline; copy this to ".env"
# at the project root to override them.

# Backend
NODE_ENV=production
PORT=5000
MONGODB_URI=mongodb://spot-the-phish-mongo:27017/spot_the_phish
CLIENT_ORIGIN=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# JWT
JWT_ACCESS_SECRET=changeme-min-16-chars
JWT_REFRESH_SECRET=changeme-min-16-chars

# Admin credentials
ADMIN_USERNAME=admin22
ADMIN_PASSWORD=changeme
ADMIN_JWT_SECRET=your-admin-jwt-secret-min-16-chars

# Frontend
FRONTEND_PORT=3000
VITE_API_BASE=/api
